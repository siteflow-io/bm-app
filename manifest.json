{
  "name": "Budget Meney",
  "short_name": "Budget",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#f2f4f8",
  "theme_color": "#4f46e5",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "./share-import",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "csvfiles",
          "accept": [
            "text/csv",
            "text/plain",
            "text/comma-separated-values",
            "text/*",
            "application/csv",
            "application/vnd.ms-excel",
            "application/octet-stream",
            ".csv",
            ".CSV",
            ".txt"
          ]
        }
      ]
    }
  }
}
